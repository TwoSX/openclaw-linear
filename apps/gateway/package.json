{
  "name": "openclaw-linear-gateway",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
